# D-ID API Key (from studio.d-id.com → Settings → API)
DID_API_KEY=your_did_api_key_here

# Gemini API Key (from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# ── TTS Provider ──────────────────────────────────────────────
# 'microsoft' (DEFAULT) = free, works on D-ID trial accounts
# 'elevenlabs'          = REQUIRES a PAID D-ID plan
TTS_PROVIDER=microsoft

# Microsoft Arabic voices (free on D-ID):
#   ar-EG-ShakirNeural   (Egyptian male - default)
#   ar-SA-HamedNeural    (Saudi male)
#   ar-EG-SalmaNeural    (Egyptian female)
#   ar-SA-ZariyahNeural  (Saudi female)
MICROSOFT_VOICE_ID=ar-EG-ShakirNeural

# ElevenLabs (only used if TTS_PROVIDER=elevenlabs — needs paid D-ID plan)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Public URL of Majed's image (upload to Cloudinary/imgbb/etc)
# D-ID requires a publicly accessible HTTPS URL (not localhost)
AVATAR_IMAGE_URL=https://your-image-url.com/majed.png

PORT=3000
